package com.greentree.commons.data.resource

/**
 * Интерфейс ресурса-директории (папки) в абстрактной файловой системе.
 * Директория может содержать дочерние ресурсы (файлы и поддиректории).
 * 
 * @see ChildResource
 * @see ParentResource
 * @see MutableFolderResource
 * @see InMemoryFolderResource
 */
interface FolderResource : ChildResource, ParentResource {

	/**
	 * Директория не является файлом.
	 * @return false
	 */
	override val isFile
		get() = false
	/**
	 * Директория является директорией.
	 * @return true
	 */
	override val isDirectory
		get() = true
}
